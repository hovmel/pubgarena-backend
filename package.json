{
  "name": "pubgarena-backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "nodemon --exec babel-node -r dotenv/config src/bin/www",
    "dev": "nodemon --exec babel-node -r dotenv/config src/bin/www",
    "clean": "rm -rf dist",
    "build": "yarn clean && babel ./src --out-dir dist --copy-files",
    "prod": "yarn build && node -r dotenv/config ./dist/bin/www"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "~1.4.4",
    "core-js": "^3.35.1",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^16.0.0",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "jade": "~1.11.0",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^8.1.1",
    "morgan": "~1.9.1",
    "nodemailer": "^6.9.16",
    "multer": "1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "regenerator-runtime": "^0.14.1",
    "sharp": "^0.33.5",
    "stripe": "^17.4.0",
    "telegraf": "^4.16.3",
    "validatorjs": "^3.22.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.9",
    "@babel/core": "^7.23.9",
    "@babel/node": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "eslint": "^8.11.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.25.4",
    "nodemon": "^2.0.15"
  }
}

# Nginx default: /api -> backend (localhost:4000), / -> frontend (Analytics_frontend)
# На сервере заменить: sudo cp nginx/default /etc/nginx/sites-available/default
# Проверить: sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    root /var/www/analytics/Analytics_frontend;
    index index.html;

    # API — проксируем на бэкенд
    #location /api/ {
    #    proxy_pass http://127.0.0.1:4000/api/;
    #    proxy_http_version 1.1;
    #    proxy_set_header Host $host;
    #    proxy_set_header X-Real-IP $remote_addr;
    #    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #    proxy_set_header X-Forwarded-Proto $scheme;
    #}

    # API — проксируем на бэкенд pubgarena-backend
    location /api/ {
        proxy_pass http://127.0.0.1:4000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Корень и всё остальное — фронтенд (SPA: отдаём index.html для любых путей)
    location / {
        try_files $uri $uri/ /index.html;
    }
}


server {
    server_name matchai.live; # managed by Certbot

    root /var/www/analytics/Analytics_frontend;
    index index.html;

    # API — проксируем на бэкенд
    location /api/ {
        proxy_pass http://127.0.0.1:4000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Корень и всё остальное — фронтенд (SPA: отдаём index.html для любых путей)
    location / {
        try_files $uri $uri/ /index.html;
    }


    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/matchai.live/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/matchai.live/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

server {
    if ($host = matchai.live) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80 ;
    listen [::]:80 ;
    server_name matchai.live;
    return 404; # managed by Certbot
}

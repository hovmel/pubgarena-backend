PORT=4000
DB_NAME=pubgarena
# MONGODB_URI=mongodb://localhost:27017/pubgarena

JWT_KEY=change_me_in_production
JWT_EXPIRES_DAYS=30

MAX_FIELDS_SIZE_MB=10

# Почта (код подтверждения регистрации, как в Nomad-Back). Без SMTP код пишется только в лог сервера.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
# Необязательно: адрес «От» (по умолчанию = SMTP_USER)
# SMTP_FROM=noreply@example.com

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# URLs for Checkout redirects (your frontend or placeholder)
APP_PUBLIC_URL=http://localhost:3000

# Seed two admins on first DB connection (passwords hashed with bcrypt)
SEED_ADMINS_ON_START=true
SEED_ADMIN_1_EMAIL=admin1@pubgarena.local
SEED_ADMIN_1_PASSWORD=ChangeMeAdmin1!
SEED_ADMIN_1_NAME=Admin One
SEED_ADMIN_2_EMAIL=admin2@pubgarena.local
SEED_ADMIN_2_PASSWORD=ChangeMeAdmin2!
SEED_ADMIN_2_NAME=Admin Two

# Optional: Telegraf bot (not used until implemented)
# TELEGRAM_BOT_TOKEN=

# Optional: PUBG third-party API (not used until implemented)
# PUBG_API_KEY=
